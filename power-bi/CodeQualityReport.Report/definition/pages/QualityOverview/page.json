{
  "name": "QualityOverview",
  "displayName": "Quality Overview",
  "displayOption": 1,
  "width": 1280,
  "height": 720,
  "ordinal": 0,
  "visualContainers": [
    {
      "name": "stackedBarFindingsBySeverity",
      "position": { "x": 16, "y": 80, "z": 0, "width": 580, "height": 340 },
      "visual": {
        "visualType": "stackedBarChart",
        "projections": {
          "Category": [{ "queryRef": "Fact_CodeQualityFindings.repo_name" }],
          "Y": [{ "queryRef": "Fact_CodeQualityFindings.finding_id", "aggregation": "Count" }],
          "Series": [{ "queryRef": "Fact_CodeQualityFindings.severity" }]
        },
        "title": "Findings by Severity per Repository"
      }
    },
    {
      "name": "kpiTotalFindings",
      "position": { "x": 16, "y": 16, "z": 1, "width": 200, "height": 56 },
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Fact_CodeQualityFindings.finding_id", "aggregation": "Count" }]
        },
        "title": "Total Findings"
      }
    },
    {
      "name": "kpiAvgCoverage",
      "position": { "x": 224, "y": 16, "z": 2, "width": 200, "height": 56 },
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.[Avg Coverage %]" }]
        },
        "title": "Avg Coverage %"
      }
    },
    {
      "name": "kpiAvgComplexity",
      "position": { "x": 432, "y": 16, "z": 3, "width": 200, "height": 56 },
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.[Avg Complexity]" }]
        },
        "title": "Avg Complexity"
      }
    },
    {
      "name": "slicerRepo",
      "position": { "x": 616, "y": 80, "z": 4, "width": 200, "height": 140 },
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "Repositories.repo_name" }]
        },
        "title": "Repository"
      }
    },
    {
      "name": "slicerDateRange",
      "position": { "x": 824, "y": 80, "z": 5, "width": 200, "height": 140 },
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "Dim_Date.Date" }]
        },
        "title": "Scan Date Range",
        "objects": {
          "general": [{ "properties": { "filter": { "type": "Between" } } }]
        }
      }
    },
    {
      "name": "slicerTool",
      "position": { "x": 1032, "y": 80, "z": 6, "width": 200, "height": 140 },
      "visual": {
        "visualType": "slicer",
        "projections": {
          "Values": [{ "queryRef": "ScanTools.display_name" }]
        },
        "title": "Scan Tool"
      }
    },
    {
      "name": "detailTable",
      "position": { "x": 16, "y": 428, "z": 7, "width": 1248, "height": 280 },
      "visual": {
        "visualType": "tableEx",
        "projections": {
          "Values": [
            { "queryRef": "Fact_CodeQualityFindings.repo_name" },
            { "queryRef": "Fact_CodeQualityFindings.rule_id" },
            { "queryRef": "Fact_CodeQualityFindings.severity" },
            { "queryRef": "Fact_CodeQualityFindings.category" },
            { "queryRef": "Fact_CodeQualityFindings.file_path" },
            { "queryRef": "Fact_CodeQualityFindings.line_number" },
            { "queryRef": "Fact_CodeQualityFindings.metric_value" },
            { "queryRef": "ScanTools.display_name" }
          ]
        },
        "title": "Finding Details"
      }
    }
  ]
}
