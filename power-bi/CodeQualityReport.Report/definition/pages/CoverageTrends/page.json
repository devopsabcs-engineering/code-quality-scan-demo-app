{
  "name": "CoverageTrends",
  "displayName": "Coverage Trends",
  "displayOption": 1,
  "width": 1280,
  "height": 720,
  "ordinal": 1,
  "visualContainers": [
    {
      "name": "lineChartCoverageOverTime",
      "position": { "x": 16, "y": 16, "z": 0, "width": 800, "height": 340 },
      "visual": {
        "visualType": "lineChart",
        "projections": {
          "Category": [{ "queryRef": "Dim_Date.Date" }],
          "Y": [{ "queryRef": "Measures.[Avg Coverage %]" }],
          "Series": [{ "queryRef": "Fact_CodeQualityFindings.repo_name" }]
        },
        "title": "Coverage % Over Time",
        "objects": {
          "constantLine": [
            {
              "properties": {
                "value": 80,
                "label": "80% Threshold",
                "style": "dashed",
                "color": "#FF4444"
              }
            }
          ]
        }
      }
    },
    {
      "name": "heatmapCoverageByFile",
      "position": { "x": 16, "y": 364, "z": 1, "width": 800, "height": 340 },
      "visual": {
        "visualType": "matrix",
        "projections": {
          "Rows": [{ "queryRef": "Fact_CodeQualityFindings.file_path" }],
          "Columns": [{ "queryRef": "Dim_Date.MonthYear" }],
          "Values": [{ "queryRef": "Measures.[Avg Coverage %]" }]
        },
        "title": "Coverage by File (Heatmap)",
        "objects": {
          "values": [
            {
              "properties": {
                "conditionalFormatting": {
                  "minColor": "#FF4444",
                  "midColor": "#FFCC00",
                  "maxColor": "#44BB44",
                  "minValue": 0,
                  "midValue": 50,
                  "maxValue": 100
                }
              }
            }
          ]
        }
      }
    },
    {
      "name": "gaugeCoverageThreshold",
      "position": { "x": 824, "y": 16, "z": 2, "width": 440, "height": 340 },
      "visual": {
        "visualType": "gauge",
        "projections": {
          "Y": [{ "queryRef": "Measures.[Avg Coverage %]" }],
          "TargetValue": [{ "queryRef": "Measures.[Coverage Threshold]" }],
          "MinValue": [{ "value": 0 }],
          "MaxValue": [{ "value": 100 }]
        },
        "title": "Current Coverage vs Threshold",
        "objects": {
          "axis": [
            {
              "properties": {
                "min": 0,
                "max": 100,
                "target": 80
              }
            }
          ]
        }
      }
    },
    {
      "name": "cardCoverageBelow",
      "position": { "x": 824, "y": 364, "z": 3, "width": 200, "height": 80 },
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.[Files Below Threshold]" }]
        },
        "title": "Files Below 80%"
      }
    },
    {
      "name": "cardCoverageAbove",
      "position": { "x": 1032, "y": 364, "z": 4, "width": 200, "height": 80 },
      "visual": {
        "visualType": "card",
        "projections": {
          "Values": [{ "queryRef": "Measures.[Files Above Threshold]" }]
        },
        "title": "Files Above 80%"
      }
    }
  ]
}
