{
  "name": "DuplicationReport",
  "displayName": "Duplication Report",
  "displayOption": 1,
  "width": 1280,
  "height": 720,
  "ordinal": 3,
  "visualContainers": [
    {
      "name": "treemapDuplicatedBlocks",
      "position": { "x": 16, "y": 16, "z": 0, "width": 620, "height": 400 },
      "visual": {
        "visualType": "treemap",
        "projections": {
          "Group": [
            { "queryRef": "Fact_CodeQualityFindings.repo_name" },
            { "queryRef": "Fact_CodeQualityFindings.file_path" }
          ],
          "Values": [{ "queryRef": "Fact_CodeQualityFindings.metric_value", "aggregation": "Sum", "label": "Duplicated Lines" }]
        },
        "title": "Duplicated Blocks by File",
        "description": "Size represents number of duplicated lines; grouped by repository and file"
      }
    },
    {
      "name": "barChartDuplicationComparison",
      "position": { "x": 644, "y": 16, "z": 1, "width": 620, "height": 400 },
      "visual": {
        "visualType": "clusteredBarChart",
        "projections": {
          "Category": [{ "queryRef": "Fact_CodeQualityFindings.repo_name" }],
          "Y": [
            { "queryRef": "Measures.[Total Duplicated Lines]" },
            { "queryRef": "Measures.[Duplication %]" }
          ]
        },
        "title": "Duplication Comparison by Repository",
        "objects": {
          "constantLine": [
            {
              "properties": {
                "value": 10,
                "label": "10-line threshold",
                "style": "dashed",
                "color": "#FF4444"
              }
            }
          ]
        }
      }
    },
    {
      "name": "detailTableDuplication",
      "position": { "x": 16, "y": 424, "z": 2, "width": 1248, "height": 280 },
      "visual": {
        "visualType": "tableEx",
        "projections": {
          "Values": [
            { "queryRef": "Fact_CodeQualityFindings.file_path", "label": "Source File" },
            { "queryRef": "Fact_CodeQualityFindings.line_number", "label": "Start Line" },
            { "queryRef": "Fact_CodeQualityFindings.metric_value", "label": "Duplicated Lines" },
            { "queryRef": "Fact_CodeQualityFindings.repo_name" },
            { "queryRef": "Languages.display_name", "label": "Language" },
            { "queryRef": "Fact_CodeQualityFindings.severity" },
            { "queryRef": "Dim_Date.Date", "label": "Detected On" }
          ]
        },
        "title": "Duplication Details",
        "objects": {
          "general": [
            {
              "properties": {
                "filter": {
                  "type": "Basic",
                  "column": "Fact_CodeQualityFindings.category",
                  "operator": "In",
                  "values": ["duplication"]
                }
              }
            }
          ]
        }
      }
    }
  ]
}
