	partition Fact_CodeQualityFindings = m
		mode: import
		source =
				let
					StorageUrl = "https://" & StorageAccountName & ".dfs.core.windows.net/" & ContainerName,
					Source = AzureStorage.DataLake(StorageUrl),
					FilteredRows = Table.SelectRows(Source, each Text.EndsWith([Name], ".json")),
					ParsedContent = Table.AddColumn(FilteredRows, "ParsedJson", each let p = Json.Document([Content]) in if p is list then p else {p}),
					ExpandedRows = Table.ExpandListColumn(ParsedContent, "ParsedJson"),
					ExpandedCols = Table.ExpandRecordColumn(ExpandedRows, "ParsedJson",
						{"finding_id", "repo_name", "rule_id", "severity", "tool_name",
						 "scan_date", "file_path", "line_number", "function_name",
						 "category", "metric_value", "threshold", "language"})
				in
					ExpandedCols

	annotation PBI_NavigationStepName = Navigation

	annotation PBI_ResultType = Table

