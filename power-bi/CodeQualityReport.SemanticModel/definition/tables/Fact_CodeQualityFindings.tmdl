table Fact_CodeQualityFindings
	lineageTag: f1a2b3c4-d5e6-7890-f1a2-b3c4d5e67890

	measure 'Total Findings' = COUNTROWS(Fact_CodeQualityFindings)
		formatString: 0
		lineageTag: f1a20001-0000-0000-0000-000000000001

	measure 'Avg Coverage %' = CALCULATE(AVERAGE(Fact_CodeQualityFindings[metric_value]), Fact_CodeQualityFindings[category] = "coverage")
		formatString: 0.0%
		lineageTag: f1a20002-0000-0000-0000-000000000002

	measure 'Avg Complexity' = CALCULATE(AVERAGE(Fact_CodeQualityFindings[metric_value]), Fact_CodeQualityFindings[category] = "complexity")
		formatString: 0.0
		lineageTag: f1a20003-0000-0000-0000-000000000003

	measure 'Files Below Threshold' = CALCULATE(DISTINCTCOUNT(Fact_CodeQualityFindings[file_path]), Fact_CodeQualityFindings[category] = "coverage", Fact_CodeQualityFindings[metric_value] < 80)
		formatString: 0
		lineageTag: f1a20004-0000-0000-0000-000000000004

	measure 'Critical Findings' = CALCULATE(COUNTROWS(Fact_CodeQualityFindings), Fact_CodeQualityFindings[severity] = "CRITICAL")
		formatString: 0
		lineageTag: f1a20005-0000-0000-0000-000000000005

	measure 'High Findings' = CALCULATE(COUNTROWS(Fact_CodeQualityFindings), Fact_CodeQualityFindings[severity] = "HIGH")
		formatString: 0
		lineageTag: f1a20006-0000-0000-0000-000000000006

	measure 'Repositories Scanned' = DISTINCTCOUNT(Fact_CodeQualityFindings[repo_name])
		formatString: 0
		lineageTag: f1a20007-0000-0000-0000-000000000007

